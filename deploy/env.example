# Copy to .env in repo root (optional). Docker Compose reads .env automatically.

POSTGRES_PASSWORD=сhange_me_postgres_password
RABBITMQ_DEFAULT_USER=change_me_rabbit_user
RABBITMQ_DEFAULT_PASS=change_me_rabbit_password

# Demo users are optional and disabled by default.
AUTH_SEED_ENABLED=false
AUTH_SEED_CLIENT_PASSWORD=
AUTH_SEED_MANAGER_PASSWORD=
AUTH_SEED_ADMIN_PASSWORD=

# Optional: RSA private key PEM for Auth in Production (single line with \n for newlines, or use file mount).
# Leave unset for Development ephemeral signing key.
JWT_PRIVATE_KEY_PEM=
