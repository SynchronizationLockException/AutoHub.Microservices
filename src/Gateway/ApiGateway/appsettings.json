{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "AutoHub.Auth",
    "Audience": "AutoHub.Clients",
    "JwksUrl": ""
  },
  "Observability": {
    "OtlpEndpoint": "http://otel-collector:4317"
  },
  "ReverseProxy": {
    "Routes": {
      "well-known-jwks": {
        "Order": 1,
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/.well-known/{**catch-all}"
        }
      },
      "auth-route": {
        "Order": 10,
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/auth"
          }
        ]
      },
      "catalog-route": {
        "Order": 10,
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/catalog/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/catalog"
          }
        ]
      },
      "rental-route": {
        "Order": 10,
        "ClusterId": "rental-cluster",
        "Match": {
          "Path": "/rentals/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/rentals"
          }
        ]
      },
      "sales-route": {
        "Order": 10,
        "ClusterId": "sales-cluster",
        "Match": {
          "Path": "/sales/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/sales"
          }
        ]
      },
      "payments-route": {
        "Order": 10,
        "ClusterId": "payments-cluster",
        "Match": {
          "Path": "/payments/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/payments"
          }
        ]
      },
      "notifications-route": {
        "Order": 10,
        "ClusterId": "notifications-cluster",
        "Match": {
          "Path": "/notifications/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/notifications"
          }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-api": {
            "Address": "http://auth-service:8080/"
          }
        }
      },
      "catalog-cluster": {
        "Destinations": {
          "catalog-api": {
            "Address": "http://car-catalog-service:8080/"
          }
        }
      },
      "rental-cluster": {
        "Destinations": {
          "rental-api": {
            "Address": "http://rental-service:8080/"
          }
        }
      },
      "sales-cluster": {
        "Destinations": {
          "sales-api": {
            "Address": "http://sales-service:8080/"
          }
        }
      },
      "payments-cluster": {
        "Destinations": {
          "payments-api": {
            "Address": "http://payment-service:8080/"
          }
        }
      },
      "notifications-cluster": {
        "Destinations": {
          "notifications-api": {
            "Address": "http://notification-service:8080/"
          }
        }
      }
    }
  }
}
